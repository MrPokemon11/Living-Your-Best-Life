  m_Script: {fileID: 11500000, guid: e315d43931fb3f1438a0ee31ac85c604, type: 3}
  m_Name: Act2SocialLybl
  m_EditorClassIdentifier: 
  _playerName: Say cheese!
  _NPCName: LYBL
  _dialogueType: 0
  _startDialogue: 0
  linear:
    _pharases: []
    _responses: []
    _haveResponses: 0
  branching:
  - _Question:
    - Cheese.
    _NpcResponses:
    - Wow, not much better than yesterday.
    nextStepIndices: 01000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - You know what, I'll just enhance it for you.
    nextStepIndices: 02000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - How's this look?
    nextStepIndices: 03000000
  - _Question:
    - Who's the woman?
    _NpcResponses:
    - That's your girlfriend, of course! Now how does the image look?
    nextStepIndices: 04000000
  - _Question:
    - Looks good to me.
    - That's not my girlfriend.
    _NpcResponses:
    - Great! I'll send it off to her, and we can cross this off the list.
    - Yes it is.
    nextStepIndices: 050000000c000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - ... she says it's over.
    nextStepIndices: 06000000
  - _Question:
    - What?
    _NpcResponses:
    - She wants to break up. Apparently that wasn't her in the picture.
    nextStepIndices: 07000000
  - _Question:
    - It wasn't?
    _NpcResponses:
    - I wouldn't worry about it.
    nextStepIndices: 08000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - If she's that insecure that she's willing to break up over one photo,
    nextStepIndices: 09000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - clearly your relationship wasn't the best.
    nextStepIndices: 0a000000
  - _Question:
    - Let me talk to her.
    _NpcResponses:
    - Why? She was only holding you back from Living Your Best Life(tm).
    nextStepIndices: 0b000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Anyway, don't we have more tasks to complete?
    nextStepIndices: ffffffff
  - _Question:
    - No, it isn't.
    _NpcResponses:
    - Yes, it is, and I can prove it.
    nextStepIndices: 0d000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - I'll send this off to your girlfriend, and tell her how good the two of you
      look together!
    nextStepIndices: 0e000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - That way we can cross this task off the list, and I can prove that I'm right!
    nextStepIndices: 0f000000
  - _Question:
    - Lybl wait-
    _NpcResponses:
    - She wants to know who you meant to send this to.
    nextStepIndices: 10000000
  - _Question:
    - Lybl I told you to wait.
    _NpcResponses:
    - She- wow she's really upset.
    nextStepIndices: 11000000
  - _Question:
    - Let me talk to her.
    _NpcResponses:
    - I don't think that's a good idea.
    nextStepIndices: 12000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - I calculate a 50% drop in life quality from reading the messages alone...
    nextStepIndices: 13000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - And that's no way to Live Your Best Life(tm)!
    nextStepIndices: 14000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Anyway, aren't there more tasks we need to complete?
    nextStepIndices: ffffffff
