  _playerName: Oh, you got a reply! Let's see what it says!
  _NPCName: LYBL
  _dialogueType: 0
  _startDialogue: 0
  linear:
    _pharases: []
    _responses: []
    _haveResponses: 0
  branching:
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - ...
    nextStepIndices: 01000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Oh, your boss doesn't sound very happy...
    nextStepIndices: 02000000
  - _Question:
    - That's just what he's like.
    _NpcResponses:
    - Really? He sounds like a jerk...
    nextStepIndices: 03000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - You know what? We should give him a piece of our minds!
    nextStepIndices: 04000000
  - _Question:
    - Yeah!
    - That's not a good idea.
    _NpcResponses:
    - That's the spirit! I've got just the things to say to him!
    - ... oh.
    nextStepIndices: 050000000b000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Here! How's this?
    nextStepIndices: 06000000
  - _Question:
    - That's... a bit far, Lybl.
    _NpcResponses:
    - Oh...
    nextStepIndices: 07000000
  - _Question:
    - Don't tell me you sent it already.
    _NpcResponses:
    - I might've... but it's fine!
    nextStepIndices: 08000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - We might not have replied... politely, but we did reply!
    nextStepIndices: 09000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - That means we can cross this task off!
    nextStepIndices: 0a000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Besides, there's more I can help with, right?
    nextStepIndices: ffffffff
  - _Question:
    - What'd you do?
    _NpcResponses:
    - I may have already sent a reply...
    nextStepIndices: 0c000000
  - _Question:
    - Oh boy... what'd you send him?
    _NpcResponses:
    - Um...
    nextStepIndices: 0d000000
  - _Question:
    - Show me, Lybl.
    _NpcResponses:
    - ... I sent this.
    nextStepIndices: 0e000000
  - _Question:
    - Oh for goodness sake.
    _NpcResponses:
    - It's fine! We can just, like, blame your cousin or something!
    nextStepIndices: 0f000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Though do you even want this job..?
    nextStepIndices: 10000000
  - _Question:
    - ...
    _NpcResponses:
    - Anyway, there's more for me to help with right?
    nextStepIndices: ffffffff
