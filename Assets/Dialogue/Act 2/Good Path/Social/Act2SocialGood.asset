  m_Script: {fileID: 11500000, guid: e315d43931fb3f1438a0ee31ac85c604, type: 3}
  m_Name: Act2SocialGood
  m_EditorClassIdentifier: 
  _playerName: Say cheese!
  _NPCName: LYBL
  _dialogueType: 0
  _startDialogue: 0
  linear:
    _pharases: []
    _responses: []
    _haveResponses: 0
  branching:
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - You're looking, um, good..?
    nextStepIndices: 01000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - But we can do better! Just give me a moment...
    nextStepIndices: 02000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Here! How does this look?
    nextStepIndices: 03000000
  - _Question:
    - Who's the woman?
    _NpcResponses:
    - That's your girlfriend! Isn't she beautiful?
    nextStepIndices: 04000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Anyway the image looks good right? I can send it to her?
    nextStepIndices: 05000000
  - _Question:
    - Looks good to me.
    - That's not my girlfriend...
    _NpcResponses:
    - Oh good, I was a little worried...
    - Oh.
    nextStepIndices: 0600000010000000
  - _Question:
    - Why would you be worried?
    _NpcResponses:
    - I wasn't entirely sure...
    nextStepIndices: 07000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Anyway, we can cross it off the list!
    nextStepIndices: 08000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Now, what else do you-
    nextStepIndices: 09000000
  - _Question:
    - What's wrong?
    _NpcResponses:
    - So um... turns out that wasn't her in the photo.
    nextStepIndices: 0a000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - And she wants to know who the other woman is.
    nextStepIndices: 0b000000
  - _Question:
    - You've got to be kidding me... let me talk to her.
    _NpcResponses:
    - No, it's fine! I'm handling it-
    nextStepIndices: 0c000000
  - _Question:
    - Lybl...
    _NpcResponses:
    - I've um. Made everything worse.
    nextStepIndices: 0d000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - She says it's over between the two of you.
    nextStepIndices: 0e000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - ... so I may have messed this up, but you still have things I can help with
      right?
    nextStepIndices: 0f000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - Let's go do those!
    nextStepIndices: ffffffff
  - _Question:
    - What do you mean, "Oh"?
    _NpcResponses:
    - I already sent the photo to her.
    nextStepIndices: 11000000
  - _Question:
    - What? Why?
    _NpcResponses:
    - You said I could!
    nextStepIndices: 12000000
  - _Question:
    - No I didn't?
    _NpcResponses:
    - Y-you did though! You said "I can send it to her"!
    nextStepIndices: 13000000
  - _Question:
    - You said that.
    _NpcResponses:
    - Oh. Oh no.
    nextStepIndices: 14000000
  - _Question:
    - What now?
    _NpcResponses:
    - She... she wants to break up.
    nextStepIndices: 15000000
  - _Question:
    - You're joking. Let me talk to her.
    _NpcResponses:
    - No no, I can handle this!
    nextStepIndices: 16000000
  - _Question:
    - (Click to continue)
    _NpcResponses:
    - That's why I'm here, right? To help you Live Your Best Life(tm)?
    nextStepIndices: 17000000
  - _Question:
    - ...
    _NpcResponses:
    - Anyway... anything else I can help with?
    nextStepIndices: ffffffff
